{
  "name": "@backblaze-labs/continue-b2-backup",
  "version": "0.3.0",
  "description": "Back up your Continue (continue.dev) chat sessions and config to Backblaze B2: incremental and encrypted.",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "continue-b2-backup": "bin/continue-b2-backup.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@backblaze-labs/agent-backup-core": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.20.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "backblaze",
    "b2",
    "backup",
    "continue",
    "continuedev",
    "vscode",
    "ai-agent",
    "coding-agent",
    "cloud-storage",
    "encryption",
    "cli",
    "b2-labs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backblaze-labs/continue-b2-backup.git"
  },
  "homepage": "https://blze.ai/storage"
}
